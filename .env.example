# Local DataHub instance (from `datahub docker quickstart`)
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_GMS_TOKEN=

# Used for the raw-exposure vs. aggregated classification step. Get a key at
# console.anthropic.com -> Settings -> API Keys (separate billing from a
# claude.ai subscription).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Fallback used automatically if the Anthropic call fails (rate limit, auth
# issue, or any other API-level error). Free key at console.mistral.ai
# (phone verification, no card needed). Not required unless the fallback
# actually triggers.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
