# Local DataHub instance (from `datahub docker quickstart`)
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_GMS_TOKEN=

# Used for the raw-exposure vs. aggregated classification step, via AWS
# Bedrock (not a plain Anthropic API key). Actual AWS credentials come from
# the normal boto3 chain (env vars, ~/.aws/credentials, `aws sso login`) --
# AWS_PROFILE below only matters if you're using a named profile.
AWS_REGION=eu-west-1
AWS_PROFILE=
# Copy this exactly from the Bedrock console's model catalog -- it does not
# match direct-API model names (e.g. "anthropic.claude-...-v1:0" or a
# "us.anthropic.claude-..." cross-region inference profile ID).
BEDROCK_MODEL_ID=

# Fallback used automatically if Bedrock raises a permission error (e.g. a
# sandbox account whose org policy blocks premium models). Free key at
# console.mistral.ai (phone verification, no card needed). Not required
# unless the fallback actually triggers.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
